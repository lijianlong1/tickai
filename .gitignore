# ====== 所有 .* 隐藏文件/目录 ======
# 忽略所有点开头的文件/目录
.*
# 但保留以下必要的配置文件
!.gitignore
!.gitattributes
!.gitkeep
!.editorconfig
!.env.example
!.eslintrc.js
!.eslintrc.json
!.eslintrc.yml
!.prettierrc
!.prettierrc.js
!.prettierrc.json
!.prettierrc.yml
!.babelrc
!.babelrc.js
!.dockerignore
!.npmrc
!.yarnrc
!.yarnrc.yml
!.nvmrc
!.node-version
!.python-version
!.travis.yml
!.gitlab-ci.yml
!.circleci/

